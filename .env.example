# --- Database (required) ---
#
# Recommended for local + production: Neon (https://neon.tech). Create a project, copy the connection
# string from the dashboard. Use the *pooler* URL for serverless (Prisma + Vercel).
#
# Neon + Prisma tips:
#   - DATABASE_URL: use the *pooled* / pooler host (ends in -pooler) + ?sslmode=require&pgbouncer=true
#   - DIRECT_URL: use the *direct* connection string from Neon (no -pooler). Prisma Migrate and Vercel's
#     build need this; the pooler often causes P1001 or migration issues from CI.
#   - Remove channel_binding=require if Neon added it — it often breaks the pooler with Prisma.
#   - Optional on pooler URL: &connection_limit=5&pool_timeout=30&connect_timeout=60 (helps cold start)
#
# Paste YOUR Neon URLs below (do not commit real URLs to git — only in local .env):
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
#
# Optional local Postgres instead of Neon (Postgres.app / Homebrew). Example:
# DATABASE_URL="postgresql://postgres:dev@localhost:5432/postgres"
#
# Alternative host: Supabase Postgres (still use Prisma + NextAuth — see docs/SUPABASE_MIGRATION.md).
#   - DATABASE_URL: Transaction pooler (often port 6543) with pgbouncer=true per Supabase "Prisma" docs
#   - DIRECT_URL: Direct connection (port 5432) for prisma migrate deploy
#
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: app name in UI, invites, SMS (defaults to "Tour Me Like It's Hot")
# NEXT_PUBLIC_APP_NAME="Tour Me Like It's Hot"

# Optional: public URL for invite/SMS links when you run `npm run dev` on localhost but recipients open
# links on their phone. Set to your production site (same as NEXTAUTH_URL on Vercel). On Vercel itself,
# Host usually suffices; this is mainly for local dev.
# PUBLIC_APP_URL="https://your-production-domain.com"

# Optional: shareable beta signup — set a long random string (e.g. openssl rand -hex 32).
# Share: {NEXTAUTH_URL}/join/{BETA_JOIN_SECRET} — testers create viewer account + Person profile.
# Leave unset to disable public self-signup.
# BETA_JOIN_SECRET=""

# Google OAuth (optional - add to enable "Sign in with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000/api/auth/callback/google to Authorized redirect URIs
# GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-client-secret"

# Email via Resend (invites + password reset) – https://resend.com/api-keys
# Production (e.g. Vercel): set RESEND_API_KEY or no email is sent (check deployment logs for "[forgot-password] Resend did not send").
# With default onboarding@resend.dev, Resend returns 403 for other recipients ("only send testing emails to your own email address").
# For real users: verify a domain at https://resend.com/domains , then set e.g. RESEND_FROM_EMAIL="noreply@yourdomain.com" (Vercel + redeploy).
RESEND_API_KEY="re_xxxx"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Flight lookup via aviationstack – get key at https://aviationstack.com/signup/free
AVIATIONSTACK_ACCESS_KEY=""
